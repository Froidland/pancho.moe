---
interface Props {
	href?: string;
	title?: string;
	"aria-label"?: string;
}

const { href, title, "aria-label": ariaLabel } = Astro.props;
---

{
	href ? (
		<a {href} {title} aria-label={ariaLabel} class="button">
			<slot />
		</a>
	) : (
		<button {title} aria-label={ariaLabel} class="button">
			<slot />
		</button>
	)
}

<style>
	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: 0.25rem;
		background-color: #2e2e33;
		padding: 6px 14px;
		font-weight: 500;
		color: #dbdbdc;
		transition: all 0.15s ease;
	}
	.button:hover {
		background-color: #3d3d43;
	}
</style>
