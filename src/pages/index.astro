---
import FileSaveRoundedIcon from "@/components/icons/FileSaveRoundedIcon.astro";
import BlueSkyHoverableIcon from "@/components/icons/hoverable/BlueSkyHoverableIcon.astro";
import GithubHoverableIcon from "@/components/icons/hoverable/GithubHoverableIcon.astro";
import GmailHoverableIcon from "@/components/icons/hoverable/GmailHoverableIcon.astro";
import LinkedInHoverableIcon from "@/components/icons/hoverable/LinkedInHoverableIcon.astro";
import ProtonMailHoverableIcon from "@/components/icons/hoverable/ProtonMailHoverableIcon.astro";
import TwitterHoverableIcon from "@/components/icons/hoverable/TwitterHoverableIcon.astro";
import Button from "@/components/ui/Button.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Francisco Hauva | Home">
	<main>
		<div class="profile">
			<div>
				<h1 class="text-4xl font-bold">Hey there :D</h1>
			</div>
			<ul class="flex gap-x-3 py-3">
				<li>
					<a href="mailto:phauva@gmail.com" title="Gmail" aria-label="Gmail">
						<GmailHoverableIcon size="2.5rem" />
					</a>
				</li>
				<li>
					<a href="mailto:phauva@proton.me" title="Protonmail" aria-label="Protonmail">
						<ProtonMailHoverableIcon size="2.5rem" />
					</a>
				</li>
				<li>
					<a href="https://github.com/Froidland" title="Github" aria-label="Github">
						<GithubHoverableIcon size="2.5rem" />
					</a>
				</li>
				<li>
					<a
						href="https://www.linkedin.com/in/francisco-hauva/"
						title="Linkedin"
						aria-label="Linkedin"
					>
						<LinkedInHoverableIcon size="2.5rem" />
					</a>
				</li>
				<li>
					<a href="https://twitter.com/NotPanchowo" title="Twitter" aria-label="Twitter">
						<TwitterHoverableIcon size="2.5rem" />
					</a>
				</li>
				<li>
					<a href="https://bsky.app/profile/pancho.moe" title="Bluesky" aria-label="Bluesky">
						<BlueSkyHoverableIcon size="2.5rem" />
					</a>
				</li>
			</ul>
			<Button
				href="https://url.pancho.moe/public_resume"
				title="Download resume/cv"
				aria-label="Download resume/cv"
			>
				<FileSaveRoundedIcon size="2rem" /> Resume / CV
			</Button>
		</div>
	</main>
</BaseLayout>

<style>
	main {
		position: relative;
		min-height: calc(100dvh - var(--header-height) - var(--footer-height));
		max-width: calc(var(--main-width) + var(--gap) * 2);
		margin: auto;
		padding: var(--gap);
	}

	.profile {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		height: calc(100dvh - var(--header-height) - var(--footer-height) - (var(--gap) * 2));
		text-align: center;
	}
</style>
